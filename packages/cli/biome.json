{
    "root": false,
    "$schema": "https://biomejs.dev/schemas/2.4.11/schema.json",
    "assist": { "actions": { "source": { "organizeImports": "on" } } },
    "linter": {
        "enabled": true,
        "rules": {
            "recommended": true,
            "complexity": {
                "noExcessiveCognitiveComplexity": "warn",
                "noForEach": "off",
                "noStaticOnlyClass": "off"
            },
            "suspicious": {
                "noExplicitAny": "warn",
                "noAssignInExpressions": "off"
            },
            "style": {
                "noNonNullAssertion": "off"
            }
        }
    },
    "formatter": {
        "enabled": true,
        "indentStyle": "space",
        "indentWidth": 4
    },
    "files": {
        "includes": [
            "**",
            "!**/node_modules",
            "!**/dist",
            "!**/.git",
            "!**/*.md",
            "!**/.opencode",
            "!**/*.json",
            "!**/docs-site/.astro",
            "!**/venv/**",
            "!**/.venv/**",
            "!**/venv_validation/**",
            "!**/*.d.ts"
        ]
    }
}
