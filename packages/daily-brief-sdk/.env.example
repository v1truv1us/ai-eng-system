# Copy this file to ~/.claude/cook-and-brief/.env and `chmod 600` it.
# Real values must NEVER be committed to git.

# SMTP relay (required). Use a relay with valid SPF + DKIM (Postmark, SES,
# Mailgun) for inbox delivery; see INSTALL.md §SPF/DKIM for details.
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=apikey
SMTP_PASS=replace-with-real-token

# Where to send the brief.
SMTP_FROM=daily-brief@example.com
BRIEF_TO=you@example.com

# Atlassian MCP credentials (required). Read by the MCP client; never sent
# in any rendered output. The B3 secrets-leak guard scans for this value
# in rendered HTML and telemetry rows and refuses to write if it appears.
ATLASSIAN_API_TOKEN=replace-with-real-token
ATLASSIAN_EMAIL=you@rainfocus.com
ATLASSIAN_BASE_URL=https://rainfocus.atlassian.net

# Bitbucket / Grafana tokens are optional — without them the corresponding
# brief sections show "no source configured" instead of failing.
# BITBUCKET_API_TOKEN=replace-with-real-token
# GRAFANA_API_TOKEN=replace-with-real-token
