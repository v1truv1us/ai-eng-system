{
  "compilerOptions": {
    "target": "esnext",
    "module": "esnext",
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "skipLibCheck": true,
    "strict": true,
    "noEmit": true,
    "baseUrl": ".",
    "paths": {
      "@anthropic-ai/sdk": ["./node_modules/@anthropic-ai/sdk"],
      "@anthropic-ai/sdk/*": ["./node_modules/@anthropic-ai/sdk/*"]
    }
  },
  "include": ["runner.ts", "../shared/*.ts"]
}
