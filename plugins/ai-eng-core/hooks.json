{
  "hooks": [
    {
      "matcher": {
        "event": "notification",
        "type": "session_start"
      },
      "hooks": [
        {
          "type": "command",
          "command": "echo '🔧 AI Engineering System loaded. Key commands: /plan, /work, /review, /research'"
        }
      ]
    }
  ],
  "Stop": [
    {
      "matcher": "*",
      "hooks": [
        {
          "type": "command",
          "command": "$CLAUDE_PLUGIN_DIR/hooks/cooking-stop-hook.sh"
        }
      ]
    }
  ]
}