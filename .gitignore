node_modules/
.env
.env.*
*.log
.build/
.cache/
bun.lockb

# Root dist/ is rebuilt during publish; ignore all of it
# (was previously partially committed, but publish workflow regenerates)
dist/
.dist/

# Context engineering local storage (user-specific, not committed)
.ai-context/

# Local ai-eng config (user-specific)
.ai-eng-config.yaml

# Claude hook backups (local/dev artifacts)
.claude/hooks.backup-*/

# Runtime data (user-specific)
.ai-eng/runs/
.opencode/opencode.db*

# Backup files
*.bak

# build.ts copies these into dist/ for local CLI runs; keep them out of git
# unless/until we intentionally publish them.
dist/cli/
dist/backends/
dist/config/
dist/util/

# OpenCode build artifacts (development only)
dist/.opencode/
dist/.claude-plugin/
dist/.cursor-plugin/
dist/.gemini/

# Cursor plugin import staging (regenerate with scripts/import-cursor-plugins.ts)
tmp/

# Build scratch
build.ts.tmp

# Solo runtime database
.solo/solo.db

# Package build outputs (rebuilt during publish workflow)
packages/*/dist/
packages/toolkit/.claude-plugin/
packages/toolkit/.opencode/
packages/toolkit/.cursor-plugin/
packages/toolkit/.gemini/
packages/toolkit/.pi/
packages/toolkit/plugins/
.dist/

# Husky internal files
.husky/

# Claude build outputs (generated by build.ts from content/ + skills/)
.claude/agents/
.claude/commands/
.claude/skills/

# Pi and generic agent skill build outputs (drifted copies of canonical skills/)
# Only the skills/ subdir is derived; .pi/prompts, .pi/teams, etc. stay tracked.
.pi/skills/
.agents/skills/

# OpenCode build outputs (generated by build.ts)
# Singular (opencode 1.18) and plural (>=1.19) are both written.
.opencode/agent/
.opencode/command/
.opencode/skill/
.opencode/tool/
.opencode/agents/
.opencode/commands/
.opencode/skills/
.opencode/tools/

# Plugin build outputs (generated by build.ts)
plugins/ai-eng-*/agents/
plugins/ai-eng-*/commands/
plugins/ai-eng-*/skills/
plugins/ai-eng-*/hooks/
plugins/ai-eng-*/hooks.json
plugins/ai-eng-*/docs/
plugins/ai-eng-*/templates/
plugins/ai-eng-*/.cursor-plugin/
plugins/ai-eng-*/plugin.json

# NPM tarballs
*.tgz

# Development package.json backups (for dual package.json system)
packages/*/package.json.dev

/.crew/
/.crew
!.crew/artifacts/
!.crew/graphs/
!.crew/artifacts/.gitkeep
!.crew/graphs/.gitkeep
.claude/worktrees/

.claude/packages/

# GTM skills — vendored from LeadMagic/gtm-skills, opt-in only.
# skills-gtm/ holds the source; skills/gtm is a symlink created by
# scripts/install-gtm-skills.sh. Neither ships in the default build.
skills-gtm/
skills/gtm/

# macOS
.DS_Store
**/.DS_Store
